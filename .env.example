# ============================================================
#  HTextile — Environment Configuration
#  Copy this file to .env and fill in your Supabase values.
#  NEVER commit the actual .env file to git!
# ============================================================

# --- Supabase Database (PostgreSQL) ---
# Found in: Supabase Dashboard > Settings > Database > Connection Info
DB_HOST=db.your-project-id.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password

# Use the Pooler host (port 6543) if your server doesn't support IPv6:
# DB_HOST=aws-0-ap-south-1.pooler.supabase.com
# DB_PORT=6543

# --- Application ---
APP_ENV=production          # production | development
APP_DEBUG=false             # true only during local development
APP_URL=https://yourdomain.com/HTextile/

# --- Session ---
SESSION_LIFETIME=3600       # in seconds (1 hour)
