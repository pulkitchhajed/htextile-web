# ── Step 1: Fill in from Supabase Dashboard > Settings > Database ──

# Copy "Host" from Connection Info section:
DB_HOST=db.zedcauxdecmotvbnbqrv.supabase.co

# Port is always 5432 for direct connection (or 6543 for pooler)
DB_PORT=5432

# Database name is always "postgres" on Supabase
DB_DATABASE=postgres

# Username is always "postgres" on Supabase
DB_USER=postgres

# Copy your database password (the one you set when creating the project)
# If forgotten: Supabase Dashboard > Settings > Database > Reset database password
DB_PASSWORD=Heratextile29@

# ── Step 2: Supabase Storage API ──────────────────────────────
# Needed for Vercel file uploads to Supabase Storage
# URL: https://[your-project-id].supabase.co
SUPABASE_URL=https://zedcauxdecmotvbnbqrv.supabase.co
# Key: Supabase Dashboard > Project Settings > API > service_role secret
SUPABASE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE

# ── Optional: Use Pooler instead (if you get IPv6 connection errors) ──
# DB_HOST=aws-0-ap-south-1.pooler.supabase.com
# DB_PORT=6543

# ── Application Settings ──────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/HTextile/

# ── Session Settings ──────────────────────────────────────────
SESSION_LIFETIME=3600

